# Volcengine (火山引擎) Ark console: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ARK_API_KEY=
# The Seedream model/endpoint id you've enabled in the Ark console
ARK_IMAGE_MODEL=

# Tencent Cloud RUM (formerly Aegis) — https://console.cloud.tencent.com/rum
# Leave empty to run locally with analytics disabled (no requests fired).
VITE_RUM_ID=

# --- Backend (server/) ---
# Postgres from docker-compose (npm run db:up). Default matches docker-compose.yml.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sim_waimai
# Any random string; required in production.
JWT_SECRET=dev-secret-change-me
PORT=3001

# Tencent Cloud COS object storage — hosts both user uploads (banner/menu item/review photos,
# via server/) and the seed restaurant images (tools/migrate-images-to-cos.mjs,
# tools/backfill-images.mjs). Leave all empty in dev: user uploads fall back to local disk
# (server/uploads/); seed images need VITE_COS_BASE_URL below to load.
# User uploads always go browser -> server -> COS (the server decodes/re-encodes the image
# before forwarding it), so no bucket CORS rule is needed for uploads.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
# Optional CDN/custom domain; defaults to https://{bucket}.cos.{region}.myqcloud.com
COS_PUBLIC_BASE_URL=
# Public base URL the frontend prefixes onto seed restaurant image keys — required to build the app.
# Usually the same value as COS_PUBLIC_BASE_URL (or the bucket's default domain above).
VITE_COS_BASE_URL=

# --- 内容审核 (可选) ---
# 管理员用户名列表（逗号分隔），匹配的账号可访问 /admin/review 审核后台。只填一个用户名即为唯一超级管理员。
ADMIN_USERNAMES=
# 腾讯云内容安全（天御）：TMS 审文本、IMS 审图片。配置后用户提交的店铺/商品/评价先由 AI 审核；
# 留空则全部进入人工审核队列。可与 COS 用同一对密钥（需在 CAM 给该密钥授权 TMS/IMS，并在
# 控制台开通文本/图片内容安全服务），但必须显式填写。
# 注意：图片审核对 COS 上的图走公网 URL 拉取，要求存储桶可公开读（本地盘回落时自动改传 base64）。
TENCENT_MODERATION_SECRET_ID=
TENCENT_MODERATION_SECRET_KEY=
TENCENT_MODERATION_REGION=ap-guangzhou
# 天御控制台配置的自定义审核策略/词库 BizType（可选，留空用默认策略）。
TENCENT_TMS_BIZTYPE=
TENCENT_IMS_BIZTYPE=
