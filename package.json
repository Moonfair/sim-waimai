{
  "name": "sim-shop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "shared",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"npm -w server run dev\"",
    "dev:client": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "db:up": "docker compose up -d db",
    "db:migrate": "npm -w server run migrate",
    "db:seed": "npm -w server run seed",
    "test:server": "npm -w server run test"
  },
  "dependencies": {
    "@sim-waimai/shared": "*",
    "aegis-web-sdk": "^1.41.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.0",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
